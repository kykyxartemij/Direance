DATABASE_URL="postgresql://username:password@host/dbname?sslmode=require"
AUTH_SECRET="generate-with: npx auth secret"
AUTH_URL="http://localhost:3000"

# Email (SMTP) — leave blank in dev to use Ethereal (preview URL logged to console)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
AUTH_EMAIL_FROM="Direance <noreply@yourdomain.com>"

# OAuth — register apps at:
#   Google:  https://console.cloud.google.com/  (callback: AUTH_URL/api/auth/callback/google)
#   GitHub:  https://github.com/settings/developers  (callback: AUTH_URL/api/auth/callback/github)
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=
AUTH_GITHUB_ID=
AUTH_GITHUB_SECRET=

# Neon DB monitoring — console.neon.tech → Account Settings → API Keys
# NEON_ORG_ID: visible in console URL, e.g. org-polished-resonance-30045051
NEON_API_KEY=
# Project ID: visible in Neon console URL or Settings → General
NEON_PROJECT_ID=

# Transfer + compute plan limits (free tier defaults; storage limit comes from Neon API automatically)
NEON_TRANSFER_LIMIT_BYTES=5368709120
NEON_COMPUTE_LIMIT_CU_HOURS=100
