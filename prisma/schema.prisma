generator client {
  provider        = "prisma-client"
  output          = "../generated/prisma"
  previewFeatures = ["relationJoins"]
}

datasource db {
  provider = "postgresql"
}

// ─────────────────────────────────────────────────────────────────
//  User — central entity; owns all auth + integration credentials
// ─────────────────────────────────────────────────────────────────

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  password      String?   // null for OAuth-only users

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Auth.js relations (needed for OAuth + session adapter)
  accounts Account[]
  sessions Session[]

  mappings        FieldMapping[]
  exportSettings  ExportSetting[]
}

// ─────────────────────────────────────────────────────────────────
//  Auth.js v5 required models
// ─────────────────────────────────────────────────────────────────

model Account {
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([provider, providerAccountId])
}

model Session {
  sessionToken String   @unique
  userId       String
  expires      DateTime

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime

  @@id([identifier, token])
}

// ─────────────────────────────────────────────────────────────────
//  FieldMapping — rules for normalising source field names
//  isGlobal = visible to all users (e.g. built-in Merit.ee mapping)
//  userId   = null for global mappings
// ─────────────────────────────────────────────────────────────────

model FieldMapping {
  id         String  @id @default(uuid())
  name       String
  isGlobal   Boolean @default(false)
  reportType String  @default("pnl")
  userId     String?
  user       User?   @relation(fields: [userId], references: [id], onDelete: Cascade)

  config Json @default("{}")

  exportSettingId String?
  exportSetting   ExportSetting? @relation(fields: [exportSettingId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ─────────────────────────────────────────────────────────────────
//  ExportSetting — reusable export template
//  Stores named value categories, sheet options, and report layout.
//  FieldMapping optionally links to one ExportSetting to populate
//  the Display Name ComboBox in Row Mappings with mappedValueNames.
// ─────────────────────────────────────────────────────────────────

model ExportSetting {
  id     String @id @default(uuid())
  name   String
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Header layout: logo position, arbitrary text/placeholder cells, where the DataTable starts
  headerLayout          Json?
  applyHeaderToAllSheets Boolean  @default(false)

  // Logo stored as processed bytes (sharp-compressed JPEG, max 200 KB)
  logoData Bytes?
  logoMime String? // always "image/jpeg" after sharp processing
  logoName String? // original filename, shown in UI
  
  includeOriginalSheets  Boolean  @default(false)
  mappedValueNames       String[]

  // Back-reference required by Prisma — never selected in queries; ExportSetting does not expose FieldMappings
  fieldMappings FieldMapping[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
