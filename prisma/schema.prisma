generator client {
  provider        = "prisma-client"
  output          = "../generated/prisma"
  previewFeatures = ["relationJoins"]
}

datasource db {
  provider = "postgresql"
}

// ─────────────────────────────────────────────────────────────────
//  User — central entity; owns all auth + integration credentials
// ─────────────────────────────────────────────────────────────────

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  password      String?   // null for OAuth-only users

  // IS_ADMIN overrides all permission checks
  permissions String[] @default([])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Auth.js relations (needed for OAuth + session adapter)
  accounts Account[]
  sessions Session[]

  mappings        FieldMapping[]
  exportSettings  ExportSetting[]
  sentInvites     Invite[]
  logos           Logo[]
}

// ─────────────────────────────────────────────────────────────────
//  Invite — email-specific, single-use, 72h invite token
// ─────────────────────────────────────────────────────────────────

model Invite {
  id          String    @id @default(cuid())
  email       String    @unique   // one active invite per email
  token       String    @unique
  invitedBy   String
  inviter     User      @relation(fields: [invitedBy], references: [id], onDelete: Cascade)
  permissions String[]  @default([])
  expiresAt   DateTime

  createdAt DateTime @default(now())
}

// ─────────────────────────────────────────────────────────────────
//  Auth.js v5 required models
// ─────────────────────────────────────────────────────────────────

model Account {
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([provider, providerAccountId])
}

model Session {
  sessionToken String   @unique
  userId       String
  expires      DateTime

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime

  @@id([identifier, token])
}

// ─────────────────────────────────────────────────────────────────
//  FieldMapping — rules for normalising source field names
//  isGlobal = visible to all users (e.g. built-in Merit.ee mapping)
//  userId   = null for global mappings
// ─────────────────────────────────────────────────────────────────

model FieldMapping {
  id         String  @id @default(uuid())
  name       String
  isGlobal   Boolean @default(false)
  reportType String  @default("pnl")
  userId     String?
  user       User?   @relation(fields: [userId], references: [id], onDelete: Cascade)

  config Json @default("{}")

  exportSettingId String?
  exportSetting   ExportSetting? @relation(fields: [exportSettingId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ─────────────────────────────────────────────────────────────────
//  Logo — user-owned image asset, linked 1:1 to an ExportSetting
//  Stored as sharp-processed bytes (JPEG or PNG, max 200 KB).
// ─────────────────────────────────────────────────────────────────

model Logo {
  id     String @id @default(uuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  data Bytes
  mime String
  name String

  exportSetting ExportSetting?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
}

// ─────────────────────────────────────────────────────────────────
//  ExportSetting — reusable export template
//  Stores named value categories, sheet options, and report layout.
//  FieldMapping optionally links to one ExportSetting to populate
//  the Display Name ComboBox in Row Mappings with mappedValueNames.
// ─────────────────────────────────────────────────────────────────

model ExportSetting {
  id     String @id @default(uuid())
  name   String
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Header layout: logo position, arbitrary text/placeholder cells, where the DataTable starts
  headerLayout           Json?
  applyHeaderToAllSheets Boolean @default(false)

  // Logo linked by reference — bytes live in the Logo model
  logoId String? @unique
  logo   Logo?   @relation(fields: [logoId], references: [id], onDelete: SetNull)

  includeOriginalSheets Boolean  @default(false)
  mappedValueNames      String[]

  // Back-reference required by Prisma — never selected in queries; ExportSetting does not expose FieldMappings
  fieldMappings FieldMapping[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ─────────────────────────────────────────────────────────────────
//  RateLimit — sliding-window counters for checkUserRequestLimit / checkLoginRate
//  Managed by check_rate_limit() Postgres function (see prisma/functions.sql)
// ─────────────────────────────────────────────────────────────────

model RateLimit {
  key         String   @id
  count       Int      @default(0)
  windowStart DateTime @default(now()) @map("window_start")

  @@map("RateLimit")
}
