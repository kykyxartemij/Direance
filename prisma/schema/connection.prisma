// ─────────────────────────────────────────────────────────────────
//  Connection — external integration credentials + config
//  type: 'merit_estonia' | 'merit_poland' | 'odoo' (extend as drivers added)
//  config: non-secret per-type fields (URLs, db names, company ids)
//  secret: pgcrypto-encrypted JSON blob (api keys, passwords). Never selected
//          in listing queries — only decrypted server-side during fetch.
//  mappingId: optional link to a FieldMapping used to normalize fetched data.
//
//  `merit` is kept temporarily during the merit_estonia/merit_poland split —
//  see prisma/migrate_merit_country.sql. Remove it from this enum only after
//  that script's UPDATE step has run against every environment (no rows left
//  with type = 'merit'), then db push again.
// ─────────────────────────────────────────────────────────────────

enum ConnectionType {
  merit_estonia
  merit_poland
  odoo
}

model Connection {
  id     String         @id @default(dbgenerated("gen_random_uuid()"))
  name   String
  type   ConnectionType
  userId String
  user   User           @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Auto-load into the Dashboard report list on session start when true.
  isDefault  Boolean @default(false)

  // Which report this connection produces — drives mapping selector filtering.
  reportType String  @default("pnl")

  config Json   @default("{}")
  secret Bytes

  mappingId String?
  mapping   FieldMapping? @relation(fields: [mappingId], references: [id], onDelete: SetNull)

  search_vector Unsupported("tsvector")? // managed by fts.sql trigger

  createdAt DateTime @default(now())
  updatedAt DateTime @default(now())

  @@index([userId])
}
