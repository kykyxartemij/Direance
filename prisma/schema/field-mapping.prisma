// ─────────────────────────────────────────────────────────────────
//  FieldMapping — rules for normalising source field names
//  isGlobal = visible to all users (e.g. built-in Merit.ee mapping)
//  userId   = null for global mappings
// ─────────────────────────────────────────────────────────────────

model FieldMapping {
  id         String  @id @default(uuid())
  name       String
  isGlobal   Boolean @default(false)
  reportType String  @default("pnl")
  userId     String?
  user       User?   @relation(fields: [userId], references: [id], onDelete: Cascade)

  config Json @default("{}")

  exportSettingId String?
  exportSetting   ExportSetting? @relation(fields: [exportSettingId], references: [id], onDelete: SetNull)

  search_vector Unsupported("tsvector")? // managed by fts.sql trigger

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
