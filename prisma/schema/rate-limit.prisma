// ─────────────────────────────────────────────────────────────────
//  RateLimit — sliding-window counters for checkUserRequestLimit / checkLoginRate
//  Managed by check_rate_limit() Postgres function (see prisma/functions.sql)
// ─────────────────────────────────────────────────────────────────

model RateLimit {
  key         String   @id
  count       Int      @default(0)
  windowStart DateTime @default(now()) @map("window_start")

  @@map("RateLimit")
}
